# Пример файла секретов для Streamlit Cloud.
# Скопируйте в .streamlit/secrets.toml (он в .gitignore — не попадёт в публичный repo).
# В Streamlit Cloud секреты задаются через UI: App settings → Secrets.

# Опционально — FRED API key для подгрузки макрофичей (DXY broad, CPI, IPI и т.д.).
# Бесплатная регистрация: https://fredaccount.stlouisfed.org/apikeys
# FRED_API_KEY = "ваш_ключ_сюда"
